{
    "name": "psc-acme/tracker-billing",
    "description": "Package tracker-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\TrackerBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "league/commonmark": "^2.0",
        "symfony/symfony": "^6.3",
        "aws/aws-sdk-php": "^3.332"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}